# App
NEXTAUTH_URL=https://devpilotai.dev
APP_URL=https://devpilotai.dev
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/devpilot
DIRECT_URL=postgresql://user:password@localhost:5432/devpilot

# GitHub OAuth (required)
GITHUB_ID=your-github-oauth-app-client-id
GITHUB_SECRET=your-github-oauth-app-client-secret

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Provider
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Email Configuration (Gmail SMTP)
# Step 1: Enable 2FA on your Gmail account
# Step 2: Go to Google Account > Security > App Passwords
# Step 3: Generate an App Password for "Mail"
# Step 4: Paste the 16-character password below (with spaces removed)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=your-smtp-user@example.com
EMAIL_SERVER_PASS=your-smtp-app-password
EMAIL_FROM=hello@devpilotai.dev

# Cron
CRON_SECRET=generate-a-long-random-secret

# Optional GitHub analytics token
GITHUB_TOKEN=your-github-token

# Optional Stripe demo-to-live checkout configuration
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PRICE_PRO_MONTHLY=price_your-pro-monthly-id
STRIPE_PRICE_PRO_YEARLY=price_your-pro-yearly-id
STRIPE_PRICE_SCALE_MONTHLY=price_your-scale-monthly-id
STRIPE_PRICE_SCALE_YEARLY=price_your-scale-yearly-id
