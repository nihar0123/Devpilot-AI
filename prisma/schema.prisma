generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String               @id @default(cuid())
  name           String?
  email          String?              @unique
  emailVerified  DateTime?
  passwordHash   String?
  image          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  accounts       Account[]
  sessions       Session[]
  projects       Project[]
  assignedTasks  Task[]               @relation("TaskAssignee")
  createdTasks   Task[]               @relation("TaskCreator")
  completedTasks Task[]               @relation("TaskCompleter")
  orgMembers     OrganizationMember[]
  auditLogs      AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id         String          @id @default(cuid())
  userId     String
  orgId      String?
  name       String
  repoUrl    String?
  archived   Boolean         @default(false)
  archivedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  analyses   CodeAnalysis[]
  docs       Documentation[]
  bugReports BugReport[]
  testSuites TestSuite[]
  analytics  Analytics[]
  tasks      Task[]

  @@index([userId])
  @@index([orgId])
}

model CodeAnalysis {
  id             String   @id @default(cuid())
  projectId      String
  score          Int
  summary        String   @db.Text
  suggestions    Json
  securityIssues Json
  refactoredCode String?  @db.Text
  language       String   @default("javascript")
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Documentation {
  id            String   @id @default(cuid())
  projectId     String
  readme        String?  @db.Text
  setupGuide    String?  @db.Text
  apiDocs       String?  @db.Text
  moduleSummary String?  @db.Text
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BugReport {
  id           String   @id @default(cuid())
  projectId    String
  severity     String
  title        String
  description  String   @db.Text
  fileName     String?
  lineNumber   Int?
  codeContext  String?  @db.Text
  suggestedFix String   @db.Text
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TestSuite {
  id            String   @id @default(cuid())
  projectId     String
  language      String
  framework     String
  generatedCode String   @db.Text
  testCount     Int      @default(0)
  edgeCaseCount Int      @default(0)
  mockCount     Int      @default(0)
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Analytics {
  id           String   @id @default(cuid())
  projectId    String
  commits      Int      @default(0)
  prs          Int      @default(0)
  qualityScore Int      @default(0)
  period       String   @default("weekly")
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Organization {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  logo         String?
  website      String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  members      OrganizationMember[]
  projects     Project[]
  invites      TeamInvite[]
  tasks        Task[]
  subscription Subscription?
  auditLogs    AuditLog[]
}

model OrganizationMember {
  id       String       @id @default(cuid())
  orgId    String
  userId   String
  role     String       @default("MEMBER")
  joinedAt DateTime     @default(now())
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model TeamInvite {
  id        String       @id @default(cuid())
  orgId     String
  email     String
  role      String       @default("MEMBER")
  token     String       @unique @default(cuid())
  status    String       @default("PENDING")
  expiresAt DateTime
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Subscription {
  id        String       @id @default(cuid())
  orgId     String       @unique
  plan      String       @default("FREE")
  status    String       @default("ACTIVE")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id])
}

model Task {
  id            String       @id @default(cuid())
  orgId         String
  projectId     String
  title         String
  description   String?      @db.Text
  status        String       @default("TODO")
  priority      String       @default("MEDIUM")
  sourceType    String?
  sourceId      String?
  assigneeId    String?
  deadline      DateTime?
  createdById   String
  completedById String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id])
  completedBy   User?        @relation("TaskCompleter", fields: [completedById], references: [id])

  @@index([orgId, projectId])
  @@index([assigneeId])
}

model AuditLog {
  id        String        @id @default(cuid())
  orgId     String?
  userId    String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime      @default(now())
  org       Organization? @relation(fields: [orgId], references: [id])
  user      User?         @relation(fields: [userId], references: [id])

  @@index([orgId])
}
